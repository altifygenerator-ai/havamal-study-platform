{
  "name": "the-havamal-archive",
  "version": "0.3.1",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "validate:sources": "node scripts/validate-sources.mjs && node scripts/audit-corpus.mjs",
    "import:sources": "node scripts/import-sources.mjs",
    "seed": "node scripts/seed.mjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run validate:sources && npm test && npm run typecheck && npm run build",
    "fetch:sources": "node scripts/fetch-sources.mjs",
    "review:source": "node scripts/review-source.mjs",
    "audit:corpus": "node scripts/audit-corpus.mjs",
    "propose:alignments": "node scripts/propose-alignments.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.110.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
